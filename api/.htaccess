# APEX GLASS - Headers CORS
# Solo se permite el origen propio. estaciones.php y recibir_orden.php
# sobreescriben este header cuando necesitan acceso externo.
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "https://apex.glass"
    Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, X-API-Key"
</IfModule>

# Manejar OPTIONS directamente
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]